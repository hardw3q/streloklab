<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.pixels.steloklab.controller.ShooterController">

    <BorderPane fx:id="gameRoot" visible="false">

        <center>
            <HBox>
                <Pane fx:id="gamePaneContainer"/>

                <VBox fx:id="playersPanel" minWidth="170" prefWidth="185"
                      spacing="4" style="-fx-background-color: #ececec; -fx-padding: 8;">
                    <Label text="Игроки" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                </VBox>
            </HBox>
        </center>

        <bottom>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>

                <Button fx:id="readyButton"       text="Готов"
                        onAction="#onReady"        minWidth="80"/>
                <Button fx:id="stopButton"        text="Остановить игру"
                        onAction="#onStop"         disable="true" minWidth="120"/>
                <Button fx:id="shootButton"       text="Выстрел"
                        onAction="#onShoot"        disable="true" minWidth="80"/>
                <Button fx:id="leaderboardButton" text="Таблица лидеров"
                        onAction="#onLeaderboard"  minWidth="130"/>

                <Label fx:id="statusLabel" text="" style="-fx-font-style: italic; -fx-text-fill: #444;">
                    <HBox.margin><Insets left="12"/></HBox.margin>
                </Label>
            </HBox>
        </bottom>
    </BorderPane>

    <VBox fx:id="connectPanel" alignment="CENTER" spacing="10"
          maxWidth="320" maxHeight="340"
          style="-fx-background-color: white;
                 -fx-padding: 24;
                 -fx-border-color: #aaa;
                 -fx-border-width: 1;
                 -fx-border-radius: 6;
                 -fx-background-radius: 6;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 2);">

        <Label text="Меткий стрелок" style="-fx-font-weight: bold; -fx-font-size: 18;"/>

        <GridPane hgap="8" vgap="6">
            <Label text="Хост:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="hostField" text="localhost" prefWidth="170"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Порт:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="portField" text="12345" prefWidth="80"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Имя игрока:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="usernameField" promptText="Введите имя" prefWidth="170"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>

        <Button text="Подключиться" onAction="#onConnect"
                maxWidth="200" defaultButton="true"
                style="-fx-font-size: 13;"/>

        <Label fx:id="connectErrorLabel" text="" wrapText="true" maxWidth="280"
               style="-fx-text-fill: #c0392b;"/>
    </VBox>

</StackPane>

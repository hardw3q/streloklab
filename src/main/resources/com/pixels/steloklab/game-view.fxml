<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Priority?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.pixels.steloklab.controller.ShooterController">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="15.0">
      <padding>
        <Insets bottom="8.0" left="10.0" right="10.0" top="8.0"/>
      </padding>
      <Label text="Счёт: "/>
      <Label fx:id="scoreLabel" text="0"/>
      <Label text="Выстрелы: "/>
      <Label fx:id="shotsLabel" text="0"/>
      <HBox spacing="8.0" HBox.hgrow="ALWAYS">
        <Button text="Старт" onAction="#onStart"/>
        <Button text="Стоп" onAction="#onStop"/>
        <Button fx:id="pauseButton" text="Пауза" onAction="#onPause"/>
        <Button fx:id="shootButton" text="Выстрел" onAction="#onShoot"/>
      </HBox>
    </HBox>
  </top>
  <center>
    <Pane fx:id="gamePaneContainer"/>
  </center>
</BorderPane>
